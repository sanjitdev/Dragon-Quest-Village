{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "types": ["phaser"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
